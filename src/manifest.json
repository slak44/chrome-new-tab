{
  "manifest_version": 3,

  "name": "Custom New Tab",
  "version": "8.0.0",
  "chrome_url_overrides": {
    "newtab": "/main.html"
  },
  "options_page": "/settings.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'",
    "sandbox": "sandbox allow-scripts allow-forms allow-popups allow-modals; script-src 'self' 'unsafe-inline' 'unsafe-eval'; object-src 'self'"
  },
  "sandbox": {
    "pages": ["/sandbox.html"]
  },
  "permissions": ["storage"],
  "host_permissions": ["file:///*"],
  "optional_host_permissions": ["https://*/"],
  "icons": {
    "18": "extension-icons/ic_tab_black_18dp.png",
    "24": "extension-icons/ic_tab_black_24dp.png",
    "36": "extension-icons/ic_tab_black_36dp.png",
    "48": "extension-icons/ic_tab_black_48dp.png"
  }
}
